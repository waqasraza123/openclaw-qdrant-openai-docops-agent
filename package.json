{
  "name": "openclaw-docops-agent",
  "version": "1.0.0",
  "description": "Production-grade document ingestion + grounded Q&A + audit harness, exposed via: - CLI (ingest, ask, audit) - HTTP API (automation-ready) - OpenClaw skill (chat-native execution)",
  "main": "index.js",
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "scripts": {
    "dev": "tsx src/web/server.ts",
    "ingest": "tsx scripts/ingest.ts",
    "ask": "tsx scripts/ask.ts",
    "audit": "tsx scripts/audit.ts",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "lint": "eslint .",
    "format": "prettier -w .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "ci": "npm run typecheck && npm run lint && npm test"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@qdrant/js-client-rest": "^1.17.0",
    "dotenv": "^17.3.1",
    "openai": "^6.27.0",
    "pdf-parse": "^2.4.5",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@types/node": "^25.3.3",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  }
}
