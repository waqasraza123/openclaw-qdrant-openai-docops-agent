{
  "name": "openclaw-docops-agent",
  "version": "1.0.0",
  "description": "Production-grade document ingestion + grounded Q&A + audit harness, exposed via: - CLI (ingest, ask, audit) - HTTP API (automation-ready) - OpenClaw skill (chat-native execution)",
  "main": "index.js",
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "scripts": {
    "dev": "tsx src/web/server.ts",
    "ingest": "tsx scripts/ingest.ts",
    "ask": "tsx scripts/ask.ts",
    "audit": "tsx scripts/audit.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "ci": "npm run typecheck && npm test",
    "qdrant:check": "tsx scripts/qdrant-check.ts",
    "doc:stats": "tsx scripts/doc-stats.ts",
    "doc:delete": "tsx scripts/doc-delete.ts",
    "chunk:get": "tsx scripts/chunk-get.ts",
    "doc:list": "tsx scripts/doc-list.ts",
    "doc:export": "tsx scripts/doc-export.ts",
    "doc:info": "tsx scripts/doc-info.ts",
    "doc:registry:list": "tsx scripts/doc-registry-list.ts",
    "diagnostics": "tsx scripts/diagnostics.ts",
    "config:print": "tsx scripts/config-print.ts",
    "ask:trace": "tsx scripts/ask-trace.ts",
    "registry:rebuild": "tsx scripts/registry-rebuild.ts",
    "retrieve": "tsx scripts/retrieve.ts",
    "registry:export": "tsx scripts/registry-export.ts",
    "registry:import": "tsx scripts/registry-import.ts",
    "cache:cleanup": "tsx scripts/cache-cleanup.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier -w .",
    "format:check": "prettier -c ."
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@qdrant/js-client-rest": "^1.17.0",
    "dotenv": "^17.3.1",
    "js-tiktoken": "^1.0.21",
    "openai": "^6.27.0",
    "pdf-parse": "^2.4.5",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^25.4.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.0.18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/waqasraza123/openclaw-qdrant-openai-docops-agent.git"
  },
  "bugs": {
    "url": "https://github.com/waqasraza123/openclaw-qdrant-openai-docops-agent/issues"
  },
  "homepage": "https://github.com/waqasraza123/openclaw-qdrant-openai-docops-agent#readme"
}
